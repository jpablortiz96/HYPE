# ─────────────────────────────────────────────────────────────
# OPTION A — Amazon Aurora DSQL  (production / hackathon judging)
# Create a cluster: AWS Console -> Aurora DSQL -> Create cluster
# Then paste the cluster endpoint below.
# ─────────────────────────────────────────────────────────────
DSQL_ENDPOINT=REPLACE_ME.dsql.us-east-1.on.aws
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=REPLACE_ME
AWS_SECRET_ACCESS_KEY=REPLACE_ME
DSQL_USER=admin

# ─────────────────────────────────────────────────────────────
# OPTION B — Local PostgreSQL (dev fallback; takes priority if set)
# docker compose up -d   ->  then uncomment:
# ─────────────────────────────────────────────────────────────
# DATABASE_URL=postgres://hype:hype@localhost:5432/hype

# Random 32+ char string used to sign session cookies
SESSION_SECRET=REPLACE_ME_with_a_long_random_string_0123456789

NEXT_PUBLIC_APP_NAME=HYPE
